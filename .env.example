# =======================================
# VishwaGuru Environment Configuration
# =======================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# ===============================
# 🔐 API & Bot Configuration
# ===============================

# Telegram Bot Token
# Get your token from @BotFather on Telegram
# Steps: 1) Message @BotFather 2) /newbot 3) Follow instructions
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Example: TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Google Gemini API Key
# Get your API key from https://makersuite.google.com/app/apikey
# Free tier available with rate limits
GEMINI_API_KEY=your_gemini_api_key_here
# Example: GEMINI_API_KEY=AIzaSyABCDEF1234567890

# Hugging Face Access Token (Optional)
# Required for advanced AI features and model downloads
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
# Example: HF_TOKEN=hf_ABcdEFghIJklmnOPqrsTUvwxYZ


# ===============================
# 🗄️ Database Configuration
# ===============================

# For Local Development (SQLite)
DATABASE_URL=sqlite:///./data/issues.db

# For Production (PostgreSQL on Neon)
# Format: postgresql://user:password@host/database?sslmode=require
# DATABASE_URL=postgresql://username:password@ep-cool-name.us-east-1.aws.neon.tech/neondb?sslmode=require


# ===============================
# 🌐 Application URLs
# ===============================

# Frontend URL (used for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Backend API URL (used by frontend to make API calls)
# Development:
VITE_API_URL=http://localhost:8000

# Production (uncomment and update):
# VITE_API_URL=https://your-backend.onrender.com


# ===============================
# 🤖 Local ML Configuration
# Related to Issue #76
# ===============================

# Enable local ML inference (reduces API costs)
USE_LOCAL_ML=true

# Fallback to Hugging Face if local ML fails
ENABLE_HF_FALLBACK=true

# Device to run local ML
# Options: cpu | cuda (GPU)
LOCAL_ML_DEVICE=cpu

# Enable model quantization for faster inference
# Options: true | false
# Note: May reduce accuracy slightly
LOCAL_ML_QUANTIZE=false

# CLIP model used for local inference
# Default: openai/clip-vit-base-patch32
# Alternatives: openai/clip-vit-large-patch14 (better accuracy, slower)
LOCAL_CLIP_MODEL=openai/clip-vit-base-patch32


# ===============================
# 🔒 Security (Production Only)
# ===============================

# Secret key for session management (generate a strong random key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=your_secret_key_here

# Allowed hosts (comma-separated)
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS origins (comma-separated, for production)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com


# ===============================
# 📊 Optional: Monitoring & Logging
# ===============================

# Log level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Enable debug mode (DO NOT use in production!)
DEBUG=false


# ===============================
# 🚀 Deployment Configuration
# ===============================

# Port for backend server (default: 8000)
PORT=8000

# Number of workers (for production with Gunicorn/Uvicorn)
WORKERS=4


# ===============================
# 📝 Notes
# ===============================
# 1. Never commit your .env file to git!
# 2. Use strong, unique values for production
# 3. Rotate API keys regularly
# 4. Keep this file updated with new variables
# 5. Check SECURITY.md for best practices

